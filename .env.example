# --- Postgres ---
POSTGRES_DB=excalidraw
POSTGRES_USER=excalidraw
POSTGRES_PASSWORD=change_me

# --- Backend ---
BACKEND_PORT=8080
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d
#
# Allow frontend origin (comma-separated) for CORS, e.g. https://draw.mixdev.me
CORS_ORIGIN=https://draw.mixdev.me

# The backend connects to postgres via this URL inside docker network
DATABASE_URL=postgres://excalidraw:change_me@postgres:5432/excalidraw

# --- Frontend ---
VITE_API_BASE_URL=https://api.draw.mixdev.me
VITE_WS_BASE_URL=wss://ws.draw.mixdev.me

# Traefik is expected to be managed externally on the VPS

