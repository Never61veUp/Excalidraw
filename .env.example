# --- Postgres ---
POSTGRES_DB=excalidraw
POSTGRES_USER=excalidraw
POSTGRES_PASSWORD=change_me

# --- Backend ---
BACKEND_PORT=8080
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d

# The backend connects to postgres via this URL inside docker network
DATABASE_URL=postgres://excalidraw:change_me@postgres:5432/excalidraw

# --- Frontend ---
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=ws://localhost/room

# --- Traefik (optional TLS via Let's Encrypt) ---
TRAEFIK_ACME_EMAIL=admin@example.com
TRAEFIK_DOMAIN=example.com

